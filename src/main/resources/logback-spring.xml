<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <springProfile name="!local">
    <!-- Production / staging: JSON structured logs for log aggregation (Datadog, CloudWatch) -->
    <appender name="JSON_STDOUT" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="net.logstash.logback.encoder.LogstashEncoder">
        <includeMdcKeyName>transfer_id</includeMdcKeyName>
        <includeMdcKeyName>account_id</includeMdcKeyName>
        <includeMdcKeyName>idempotency_key</includeMdcKeyName>
      </encoder>
    </appender>
    <root level="INFO">
      <appender-ref ref="JSON_STDOUT"/>
    </root>
  </springProfile>

  <springProfile name="local,test">
    <!-- Local / test: human-readable logs -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
      <encoder>
        <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) %cyan(%logger{36}) - %msg%n</pattern>
      </encoder>
    </appender>
    <root level="INFO">
      <appender-ref ref="STDOUT"/>
    </root>
    <logger name="com.kirafintech" level="DEBUG"/>
  </springProfile>
</configuration>
